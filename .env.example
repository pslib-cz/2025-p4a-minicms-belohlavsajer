DATABASE_TARGET="sqlite"
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Set production origin here so metadata, robots.txt and sitemap.xml use the same public URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Optional analytics stay off until the visitor grants consent via CookieConsent v3.
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Vercel production example:
# DATABASE_TARGET="postgres"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
# NEXT_PUBLIC_SITE_URL="https://your-domain.example"
# NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
# NEXT_PUBLIC_CLARITY_PROJECT_ID="your-clarity-project-id"
